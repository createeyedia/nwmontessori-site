---
import Base from '../layouts/Base.astro';
---
<Base title="Northwest Montessori School — Peaceful Education Since 1965">

<!-- ═══ NAVIGATION ═══ -->
<nav class="nav" id="nav">
  <a href="/" class="nav-logo">
    <img src="/images/logo/nwm-blue.png" alt="Northwest Montessori School" />
  </a>
  <div class="nav-links">
    <a href="#story">About</a>
    <a href="#programs">Programs</a>
    <a href="#calendar">Calendar</a>
    <a href="#marietta">Marietta's Lessons</a>
    <a href="#admissions" class="nav-cta">Schedule a Visit</a>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero" id="home">
  <div class="hero-image">
    <img src="/images/campus/wg-wide.jpg" alt="Northwest Montessori classroom" />
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-line"></div>
    <div class="hero-logo">
      <img src="/images/logo/nwm-white.png" alt="Northwest Montessori School" />
    </div>
    <div class="hero-motto">Rooted in legacy. Growing our future.</div>
    <p class="hero-tagline">Peaceful education since 1965</p>
    <div class="hero-line-b"></div>
  </div>
  <div class="hero-scroll">
    <span>Discover</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ═══ MISSION ═══ -->
<section class="mission">
  <p>To provide an individualized learning environment, based on the principles of Dr.&nbsp;Maria Montessori, that helps students become independent, life-long learners who are academically grounded and socially confident about their place in the world.</p>
  <div class="mission-creds">AMI Accredited &ensp;·&ensp; Three Seattle Campuses &ensp;·&ensp; Ages 2½–12</div>
</section>

<!-- ═══ STORY ═══ -->
<section class="story" id="story">
  <div class="story-photo">
    <img src="/images/campus/geography-work.jpg" alt="Students engaged in geography and map work" />
    <div class="story-photo-inset">
      <img src="/images/archive/historical-classroom.jpg" alt="Historical NWM classroom" />
    </div>
  </div>
  <div class="story-text">
    <h2>A legacy of<br />thoughtful education</h2>
    <p>Northwest Montessori was the first AMI-accredited Montessori school in Seattle, founded in 1965 by Marietta Rawson. What began as one small classroom has grown into three campuses serving generations of Seattle families — always guided by the belief that education should honor the whole child.</p>
    <p>Today, across Woodland Park, Wedgwood, and West Seattle, we continue to offer nurturing, non-competitive, multi-age classrooms with an emphasis on the social, emotional, physical, and intellectual development of every child.</p>
    <a href="#" class="gentle-link">Read our story →</a>
  </div>
</section>

<!-- ═══ FOUNDER ═══ -->
<section class="founder" id="founder">
  <div class="founder-inner">
    <div class="founder-images">
      <div class="founder-portrait">
        <img src="/images/archive/marietta-portrait.jpg" alt="Marietta Rawson, founder of Northwest Montessori School" />
      </div>
      <div class="founder-graduation">
        <img src="/images/archive/marietta-graduation.jpg" alt="Young Marietta Rawson in academic regalia" />
      </div>
    </div>
    <div class="founder-text">
      <div class="founder-label">Our Founder</div>
      <h2>Marietta Rawson believed every child carries a unique blueprint — and that education should help reveal it, not override it.</h2>
      <p>A public school teacher who was so moved by a lecture on the Montessori method that she traveled to Italy to train with the Association Montessori Internationale, Marietta returned to Seattle and opened its first AMI-accredited Montessori school in 1965. What began in one small classroom became a home for generations of families.</p>
      <p>Her philosophy was direct: children are not to be molded into something they are not. They arrive with their own nature, their own potential, their own path toward something extraordinary. The role of the school is to prepare an environment beautiful and calm enough for that nature to emerge on its own terms.</p>
      <div class="miracle-callout">
        <div class="miracle-img">
          <img src="/images/archive/expect-a-miracle.jpg" alt="Expect a Miracle — a card Marietta Rawson gave to children at Northwest Montessori" />
        </div>
        <div class="miracle-text">
          <blockquote>"Expect a Miracle"</blockquote>
          <span class="miracle-source">A card Marietta would give to every child — a small tradition that still lives in the spirit of the school.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ PROGRAMS ═══ -->
<section class="programs" id="programs">
  <div class="programs-inner">
    <div class="section-label">Programs</div>
    <div class="program-cards">
      <div class="program-card">
        <div class="program-card-img">
          <img src="/images/archive/child-beads.jpg" alt="Child working with bead materials" />
        </div>
        <div class="program-card-body">
          <h3>Primary</h3>
          <span class="program-ages">Ages 2½–6</span>
          <p>In a carefully prepared environment, children are active explorers who gain mastery over their surroundings through self-directed work with Montessori materials. Each child progresses at their own pace within the three-year curriculum.</p>
          <a href="#" class="gentle-link">Learn more →</a>
        </div>
      </div>
      <div class="program-card">
        <div class="program-card-img">
          <img src="/images/campus/elem-focus.jpg" alt="Elementary students deeply focused on Montessori materials" />
        </div>
        <div class="program-card-body">
          <h3>Elementary</h3>
          <span class="program-ages">Ages 6–12</span>
          <p>Fueled by a deep thirst for knowledge, students freely choose their work from eight academic areas. Working alone or in small groups, they deepen their understanding through individualized lessons and exploration.</p>
          <a href="#" class="gentle-link">Learn more →</a>
        </div>
      </div>
      <div class="program-card">
        <div class="program-card-img">
          <img src="/images/campus/forest-path.jpg" alt="Children exploring a mossy Pacific Northwest forest trail" />
        </div>
        <div class="program-card-body">
          <h3>Extended Day</h3>
          <span class="program-ages">Before &amp; after school</span>
          <p>Our Early Birds and Coocadagy programs extend the school day with enrichment — art classes, swimming, nature walks, museum visits — offering flexibility for families in a warm, supportive setting.</p>
          <a href="#" class="gentle-link">Learn more →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIALS ═══ -->
<section class="testimonials">
  <div class="accent-line"></div>
  <blockquote id="tQuote">"A kind, caring, welcoming community. Students learn independence, thoughtfulness, and creative thinking in a way no traditional school can offer. A Montessori student is never lost."</blockquote>
  <cite id="tCite">A Parent</cite>
  <div class="test-dots">
    <span class="active" data-i="0"></span>
    <span data-i="1"></span>
    <span data-i="2"></span>
  </div>
</section>

<!-- ═══ MARIETTA'S LESSONS ═══ -->
<section class="marietta" id="marietta">
  <div class="marietta-inner">
    <div class="section-label" style="text-align:left;margin-bottom:36px">Marietta's Lessons</div>
    <blockquote>"We all know the feeling, it is universal, it is the same regardless of race, religion, ethnic origin, date of birth, economic status. It is a beautiful feeling, a quiet one, real tears can come to the eyes as we remember. What do we remember in this way? It is not the grand occasions, not the ceremonies or the public achievements. It is the intimate, the personal, the moment of connection…"</blockquote>
    <div class="marietta-source">— From Chapter 33: Nostalgia, by Marietta Rawson</div>
    <a href="#" class="gentle-link" style="margin-top:32px">Explore the full collection →</a>
  </div>
</section>

<!-- ═══ VIDEO ═══ -->
<section class="video-section" id="video">
  <div class="video-inner">
    <div class="video-label">Now Showing</div>
    <div class="video-title">Celebrating 60 Years of Peaceful Education</div>
    <div class="video-wrap">
      <iframe
        src="https://player.vimeo.com/video/1080296239?badge=0&autopause=0&player_id=0&app_id=58479"
        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
        title="NW Montessori 60th Anniversary Trailer"
      ></iframe>
    </div>
  </div>
</section>

<!-- ═══ CALENDAR ═══ -->
<section class="calendar-section" id="calendar">
  <div class="calendar-inner">
    <div class="section-label">School Calendar</div>
    <div class="calendar-header">
      <h3>April 2026</h3>
      <div class="calendar-nav">
        <button>← Mar</button>
        <button>May →</button>
      </div>
    </div>
    <div class="calendar-grid">
      <div class="cal-day-header">Sun</div><div class="cal-day-header">Mon</div><div class="cal-day-header">Tue</div><div class="cal-day-header">Wed</div><div class="cal-day-header">Thu</div><div class="cal-day-header">Fri</div><div class="cal-day-header">Sat</div>
      <!-- Week 1 -->
      <div class="cal-day other-month"><div class="cal-day-num">29</div></div>
      <div class="cal-day other-month"><div class="cal-day-num">30</div></div>
      <div class="cal-day other-month"><div class="cal-day-num">31</div></div>
      <div class="cal-day"><div class="cal-day-num">1</div></div>
      <div class="cal-day"><div class="cal-day-num">2</div></div>
      <div class="cal-day"><div class="cal-day-num">3</div><div class="cal-event blue">First Friday</div></div>
      <div class="cal-day"><div class="cal-day-num">4</div></div>
      <!-- Week 2 -->
      <div class="cal-day"><div class="cal-day-num">5</div></div>
      <div class="cal-day"><div class="cal-day-num">6</div><div class="cal-event green">Spring Session</div></div>
      <div class="cal-day"><div class="cal-day-num">7</div></div>
      <div class="cal-day"><div class="cal-day-num">8</div></div>
      <div class="cal-day"><div class="cal-day-num">9</div></div>
      <div class="cal-day"><div class="cal-day-num">10</div></div>
      <div class="cal-day"><div class="cal-day-num">11</div></div>
      <!-- Week 3 -->
      <div class="cal-day"><div class="cal-day-num">12</div></div>
      <div class="cal-day"><div class="cal-day-num">13</div></div>
      <div class="cal-day"><div class="cal-day-num">14</div></div>
      <div class="cal-day"><div class="cal-day-num">15</div></div>
      <div class="cal-day"><div class="cal-day-num">16</div></div>
      <div class="cal-day"><div class="cal-day-num">17</div></div>
      <div class="cal-day"><div class="cal-day-num">18</div></div>
      <!-- Week 4 -->
      <div class="cal-day"><div class="cal-day-num">19</div></div>
      <div class="cal-day"><div class="cal-day-num">20</div><div class="cal-event orange">No School</div></div>
      <div class="cal-day"><div class="cal-day-num">21</div><div class="cal-event orange">No School</div></div>
      <div class="cal-day"><div class="cal-day-num">22</div><div class="cal-event orange">No School</div></div>
      <div class="cal-day"><div class="cal-day-num">23</div><div class="cal-event orange">No School</div></div>
      <div class="cal-day"><div class="cal-day-num">24</div><div class="cal-event orange">No School</div></div>
      <div class="cal-day"><div class="cal-day-num">25</div><div class="cal-event blue">Spring Fundraiser</div></div>
      <!-- Week 5 -->
      <div class="cal-day"><div class="cal-day-num">26</div></div>
      <div class="cal-day"><div class="cal-day-num">27</div><div class="cal-event green">Classes Resume</div></div>
      <div class="cal-day"><div class="cal-day-num">28</div></div>
      <div class="cal-day"><div class="cal-day-num">29</div></div>
      <div class="cal-day"><div class="cal-day-num">30</div></div>
      <div class="cal-day other-month"><div class="cal-day-num">1</div></div>
      <div class="cal-day other-month"><div class="cal-day-num">2</div></div>
    </div>
    <div class="calendar-legend">
      <div class="legend-item"><span class="legend-dot blue"></span> School events</div>
      <div class="legend-item"><span class="legend-dot orange"></span> Closures &amp; breaks</div>
      <div class="legend-item"><span class="legend-dot green"></span> Program dates</div>
    </div>
    <div class="calendar-download">
      <a href="#">Download full 2025–2026 calendar (PDF) →</a>
    </div>
  </div>
</section>

<!-- ═══ ADMISSIONS ═══ -->
<section class="admissions" id="admissions">
  <h2>We invite you to visit</h2>
  <p>Discover whether Northwest Montessori is the right home for your child. Our admissions process is warm, unhurried, and informative.</p>
  <div class="adm-steps">
    <div class="adm-step">
      <div class="step-num">Step 1</div>
      <div class="step-title">Meet us</div>
      <div class="step-desc">Schedule a virtual or in-person meeting to learn about our philosophy and programs.</div>
    </div>
    <div class="adm-step">
      <div class="step-num">Step 2</div>
      <div class="step-title">Observe</div>
      <div class="step-desc">Visit a classroom and see the Montessori method in action with our students and guides.</div>
    </div>
    <div class="adm-step">
      <div class="step-num">Step 3</div>
      <div class="step-title">Apply</div>
      <div class="step-desc">Submit your application and begin the enrollment process for the coming school year.</div>
    </div>
  </div>
  <div class="btn-row">
    <button class="btn-primary">Schedule a Visit</button>
    <button class="btn-secondary">Learn About Admissions</button>
  </div>
</section>

<!-- ═══ FOOTER ═══ -->
<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <div class="footer-brand-logo">
        <img src="/images/logo/nwm-white.png" alt="Northwest Montessori School" />
      </div>
      <p>Rooted in legacy. Growing our future.<br />Seattle's first AMI-accredited Montessori school.</p>
    </div>
    <div class="footer-branches">
      <div>
        <div class="branch-label">Woodland Park</div>
        <div class="branch-info">4910 Phinney Ave N<br />Seattle, WA 98103</div>
        <div class="branch-phone">206.634.1347</div>
      </div>
      <div>
        <div class="branch-label">Wedgwood</div>
        <div class="branch-info">7400 25th Ave NE<br />Seattle, WA 98115</div>
        <div class="branch-phone">206.524.4244</div>
      </div>
      <div>
        <div class="branch-label">West Seattle</div>
        <div class="branch-info">4619 37th Ave SW<br />Seattle, WA 98126</div>
        <div class="branch-phone">206.933.8557</div>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 Northwest Montessori School. All rights reserved.</span>
    <span class="footer-accred">Association Montessori Internationale</span>
  </div>
</footer>

<script>
  // Nav shadow on scroll
  window.addEventListener('scroll', () => {
    document.getElementById('nav')?.classList.toggle('scrolled', window.scrollY > 40);
  });

  // Testimonial rotation
  const quotes = [
    { t: '"A kind, caring, welcoming community. Students learn independence, thoughtfulness, and creative thinking in a way no traditional school can offer. A Montessori student is never lost."', c: 'A Parent' },
    { t: '"Both children are thriving. The education is exceptionally child-centered — math, english, and science learnings have been remarkable. We have found this school to be nothing less than flexible, loving, and supportive."', c: 'A Parent' },
    { t: '"Each time I enter the classroom I see more that I like. My son is lit up with his enjoyment of school. I highly encourage an observation of the program as you work through the decision of what would be best for your child."', c: 'A Parent' },
  ];
  let cur = 0;
  const qEl = document.getElementById('tQuote');
  const cEl = document.getElementById('tCite');
  const dots = document.querySelectorAll('.test-dots span');

  if (qEl && cEl) {
    qEl.style.transition = 'opacity 0.5s';
    cEl.style.transition = 'opacity 0.5s';

    function setQ(i) {
      qEl.style.opacity = '0';
      cEl.style.opacity = '0';
      setTimeout(() => {
        cur = i;
        qEl.textContent = quotes[i].t;
        cEl.textContent = quotes[i].c;
        dots.forEach((d, j) => d.classList.toggle('active', j === i));
        qEl.style.opacity = '1';
        cEl.style.opacity = '1';
      }, 500);
    }

    dots.forEach(d => d.addEventListener('click', () => setQ(Number(d.dataset.i))));
    setInterval(() => setQ((cur + 1) % quotes.length), 7000);
  }
</script>

</Base>
